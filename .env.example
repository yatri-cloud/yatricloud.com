# Razorpay Configuration
# Get your keys from: https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY=your_razorpay_key_here
VITE_RAZORPAY_SECRET=your_razorpay_secret_here

# Google Sheets Webhook URLs
# Get your webhook URL from Google Apps Script deployment


# Provider-Specific Certification Webhook URLs
# Get these from your Google Apps Script deployments for each provider

# Udemy Configuration
# Get your credentials from: https://www.udemy.com/user/edit-api-clients/

# Udemy Webhook URLs (for Google Sheets integration)

# Proxy Configuration (for development)
VITE_PROXY_URL=http://localhost:3001

# ── Supabase (names only — put real values in .env, never commit) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_PROJECT_ID=
SUPABASE_REGION=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
VITE_USE_SUPABASE=
VITE_GOOGLE_CLIENT_ID=
# Email (server-side only — used by server.js / edge functions)
EMAIL_USER=
EMAIL_PASS=
EMAIL_HOST=
EMAIL_PORT=
# ⚠️ RAZORPAY: the secret must NEVER be VITE_-prefixed (VITE_ vars ship to the browser).
# Server-side name (used by api/razorpay + future edge functions):
RAZORPAY_KEY_SECRET=
