# Razorpay Configuration
# Get your keys from: https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY=your_razorpay_key_here
VITE_RAZORPAY_SECRET=your_razorpay_secret_here

# Google Sheets Webhook URLs
# Get your webhook URL from Google Apps Script deployment
VITE_GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_WEBHOOK_URL/exec
VOUCHER_REQUEST_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbzQN6S35tYMmEseJ-7prheC9DJ4rkBJbY3Nan7cJx5ZhZ96cbnqL-vju13IkLO80CnTtg/exec


# Provider-Specific Certification Webhook URLs
# Get these from your Google Apps Script deployments for each provider
VITE_AWS_CERTIFICATIONS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_AWS_WEBHOOK_URL/exec
VITE_AZURE_CERTIFICATIONS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_AZURE_WEBHOOK_URL/exec
VITE_GCP_CERTIFICATIONS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_GCP_WEBHOOK_URL/exec
VITE_GITHUB_CERTIFICATIONS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_GITHUB_WEBHOOK_URL/exec
VITE_ORACLE_CERTIFICATIONS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_ORACLE_WEBHOOK_URL/exec
VITE_SALESFORCE_CERTIFICATIONS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SALESFORCE_WEBHOOK_URL/exec
VITE_SERVICENOW_CERTIFICATIONS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SERVICENOW_WEBHOOK_URL/exec

# Udemy Configuration
# Get your credentials from: https://www.udemy.com/user/edit-api-clients/
VITE_UDEMY_INSTRUCTOR_TOKEN=your_udemy_instructor_token_here
VITE_UDEMY_CLIENT_ID=your_udemy_client_id_here
VITE_UDEMY_CLIENT_SECRET=your_udemy_client_secret_here

# Udemy Webhook URLs (for Google Sheets integration)
VITE_UDEMY_CREDENTIALS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_UDEMY_CREDENTIALS_WEBHOOK_URL/exec
VITE_UDEMY_YATHARTH_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_YATHARTH_WEBHOOK_URL/exec
VITE_UDEMY_NENSI_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_NENSI_WEBHOOK_URL/exec

# Proxy Configuration (for development)
VITE_PROXY_URL=http://localhost:3001
