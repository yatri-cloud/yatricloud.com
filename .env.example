# ============================================================
# Yatri Cloud — environment template
# Copy to `.env` and fill real values. NEVER commit `.env`.
# Backend is Supabase; there are NO Google Sheets / Apps Script vars.
# ============================================================

# ── Supabase (client-safe: anon/publishable keys ship to the browser) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=
VITE_USE_SUPABASE=true

# ── Supabase (server-only: never VITE_-prefixed) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=
SUPABASE_REGION=
SUPABASE_DB_PASSWORD=

# ── Google OAuth (client id is public; secret lives only in the Supabase dashboard) ──
VITE_GOOGLE_CLIENT_ID=

# ── Razorpay ──
# Public key id is browser-safe. The SECRET must NEVER be VITE_-prefixed.
VITE_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Marketplace commission (Route). Set true ONLY after Route is activated in the
# Razorpay dashboard and mentors have linked account ids. Safe default is false.
RAZORPAY_ROUTE_ENABLED=false

# ── Email (server-side only — used by server.js / Vercel functions) ──
EMAIL_USER=
EMAIL_PASS=
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_FROM_NAME=Yatri Cloud

# Cron protection for scheduled endpoints (set the same value in Vercel env).
CRON_SECRET=

# Job board — optional Adzuna free API (India + 11 countries). Get keys at developer.adzuna.com.
# Server-side only (worker), NEVER VITE_ prefixed.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Google Custom Search (referral finder). REFERRER-RESTRICTED key (yatricloud.com + localhost) — safe in browser.
VITE_GOOGLE_CSE_KEY=
